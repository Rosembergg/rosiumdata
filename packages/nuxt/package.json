{
  "name": "@rsdata/nuxt",
  "version": "0.0.1",
  "description": "RSdata Render Engine — casca Vue/Nuxt para o Data Engine",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./theme/default.css": "./src/theme/default.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/theme/default.css"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub"
  },
  "peerDependencies": {
    "nuxt": "^3.12.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@rsdata/core": "*"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "nuxt": "^3.12.0",
    "vue": "^3.4.0"
  }
}
